#include <stdio.h>
#include <math.h>

int main() {
double x1, y1;
double x2, y2;
double x3, y3;

printf("Введіть x1: ");
scanf("%lf", &x1);
printf("Введіть y1: ");
scanf("%lf", &y1);

printf("Введіть x2: ");
scanf("%lf", &x2);
printf("Введіть y2: ");
scanf("%lf", &y2);

printf("Введіть x3: ");
scanf("%lf", &x3);
printf("Введіть y3: ");
scanf("%lf", &y3);

    double a = sqrt(pow(x2 - x1, 2) + pow(y2 - y1, 2));
double b = sqrt(pow(x3 - x2, 2) + pow(y3 - y2, 2));
double c = sqrt(pow(x1 - x3, 2) + pow(y1 - y3, 2));
double P = a + b + c;
double S = fabs(x1*(y2 - y3) + x2*(y3 - y1) + x3*(y1 - y2)) / 2;
printf("У такого трикутника будуть параметри:\n");    
printf("Периметер = %.0f\n", P);
printf("Площа = %.0f\n", S);
    return 0;
}
